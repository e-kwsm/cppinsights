#include <cstdio>

int main()
{
  int x = 22;
      
  class __lambda_7_14
  {
    public: 
    inline /*constexpr */ int operator()()
    {
      ++x;
      return x;
    }
    
    // private: 
    int x;
  };
  
  int z = __lambda_7_14{x}.operator()();
  printf("x: %d z: %d\n", x, z);
  return 0;
}
